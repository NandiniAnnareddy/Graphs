from collections import deque
class Solution:
    def canFinish(self, numCourses: int, prerequisites: List[List[int]]) -> bool:
        adj = []
        queue = deque([])
        for i in range(0,numCourses):
            adj.append([])
        indegree = [0]*numCourses
        for n,m in prerequisites:
            adj[m].append(n)
        for i in adj:
            for j in i:
                indegree[j] += 1
        for i in range(0,len(indegree)):
            if indegree[i] == 0:
                queue.append(i)
        ans = []
        while(len(queue) > 0):
            node = queue.popleft()
            ans.append(node)
            for i in adj[node]:
                indegree[i] -= 1
                if indegree[i] == 0:
                    queue.append(i)
        if len(ans) == numCourses:
            return True
        else:
            return False        
