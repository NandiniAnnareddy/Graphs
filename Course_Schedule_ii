from collections import deque
class Solution:
    def findOrder(self, numCourses, prerequisites):
        adj = [[] for i in range(numCourses)]
        for a, b in prerequisites:
            adj[b].append(a)
        indegree = [0]*numCourses
        for i in adj:
            for j in i:
                indegree[j] += 1
        queue = deque()
        for i in range(numCourses):
            if indegree[i] == 0:
                queue.append(i)
        ans = []
        while queue:
            node = queue.popleft()
            ans.append(node)
            for nei in adj[node]:
                indegree[nei] -= 1
                if indegree[nei] == 0:
                    queue.append(nei)
        if len(ans) != numCourses:
            return []
        return ans
