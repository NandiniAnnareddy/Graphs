class Solution:
    def findCircleNum(self, isConnected):
        def dfs(node):
            for j in range(len(isConnected)):
                if isConnected[node][j] == 1 and visited[j] == 0:
                    visited[j] = 1
                    dfs(j)
        n = len(isConnected)
        visited = [0]*n
        count = 0
        for i in range(n):
            if visited[i] == 0:
                visited[i] = 1
                dfs(i)
                count += 1
        return count
